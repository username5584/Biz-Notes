# =============================================================================
# Environment variables for local development
# Copy this file to .env and fill in the values
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# Required for: api-server, db push/migrate
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:password@localhost:5432/mydb

# -----------------------------------------------------------------------------
# API Server (artifacts/api-server)
# -----------------------------------------------------------------------------
PORT=8080
NODE_ENV=development
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Mobile / Expo (artifacts/mobile)
# -----------------------------------------------------------------------------

# Public domain where the app is served (used for deep links and bundler)
EXPO_PUBLIC_DOMAIN=http://192.168.50.4

# Google OAuth Client ID (for Google Drive sync feature)
# Get it from: https://console.cloud.google.com/
EXPO_PUBLIC_GOOGLE_CLIENT_ID=877424969585-jsu536vlfn5shftg5r3l69o8f7mq1gk3.apps.googleusercontent.com

# Native Android/iOS Google client ID (no client secret needed — uses PKCE)
EXPO_PUBLIC_GOOGLE_NATIVE_CLIENT_ID=877424969585-jsu536vlfn5shftg5r3l69o8f7mq1gk3.apps.googleusercontent.com

# Metro bundler port (default: 18115)
METRO_PORT=18115